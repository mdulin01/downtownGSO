rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Author can update/delete anything; any auth'd user can update upvoteCount only
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount', 'commentCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /upvotes/{upvoteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /suggestions/{suggestionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /news/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /news/{articleId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    match /news/{articleId}/reactions/{reactionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{postId}/reactions/{reactionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    match /groups/{groupId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    match /groups/{groupId}/resources/{resourceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }
    // Collection group rule for collectionGroup('comments') queries (e.g. ActivityTicker)
    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }
  }
}
